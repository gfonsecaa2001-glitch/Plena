// Banco de dados do Plena.
// Postgres (Neon) — a URL vem do .env local ou das variáveis de ambiente da Vercel.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// A conta do nutricionista. Todo dado do sistema pertence a um nutricionista —
// é isso que prepara o sistema para virar SaaS multi-usuário: basta filtrar
// tudo por nutritionistId.
model Nutritionist {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String? // hash bcrypt da senha — nunca guardamos a senha em si
  role         String        @default("user") // "user" | "admin" (admin vê o painel do negócio)
  lastLoginAt  DateTime? // atualizado a cada login, pra medir uso real
  createdAt    DateTime      @default(now())

  // Conexão opcional com o Google Agenda. Fica separada do login de propósito:
  // desconectar o calendário nunca pode derrubar o acesso à conta.
  googleEmail        String? // qual conta Google está conectada (para exibir)
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?

  // Agendamento público: o paciente escolhe o horário sozinho por um link.
  bookingSlug    String?  @unique // ex.: "gabriel-fonseca" → /agendar/gabriel-fonseca
  bookingEnabled Boolean  @default(false)
  bookingDays    String   @default("1,2,3,4,5") // 1=segunda … 7=domingo
  bookingStart   Int      @default(8) // primeira hora atendida
  bookingEnd     Int      @default(18) // última hora (exclusiva)
  bookingSlotMin Int      @default(60) // duração de cada encaixe, em minutos
  patients     Patient[]
  appointments Appointment[]
}

model Patient {
  id             String        @id @default(cuid())
  nutritionistId String
  nutritionist   Nutritionist  @relation(fields: [nutritionistId], references: [id])
  name           String
  email          String?
  phone          String?
  birthDate      DateTime?
  sex            String? // "F" | "M" | "Outro"
  goal           String? // objetivo: emagrecimento, hipertrofia, saúde...
  anamnesis      String? // histórico clínico / anamnese em texto livre
  createdAt      DateTime      @default(now())
  measurements   Measurement[]
  appointments   Appointment[]
  mealPlans      MealPlan[]
}

// Uma avaliação antropométrica (medidas de uma data).
model Measurement {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  date       DateTime @default(now())
  weightKg   Float?
  heightCm   Float?
  bodyFatPct Float?
  waistCm    Float?
  hipCm      Float?
  notes      String?
}

model Appointment {
  id             String       @id @default(cuid())
  nutritionistId String
  nutritionist   Nutritionist @relation(fields: [nutritionistId], references: [id])
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime
  status         String       @default("agendada") // agendada | realizada | faltou | cancelada
  notes          String?
  googleEventId  String? // id do evento espelhado no Google Agenda (se conectado)
  source         String       @default("interno") // "interno" | "publico" (link de agendamento)
  createdAt      DateTime     @default(now())
}

// Plano alimentar. O conteúdo (refeições e alimentos) fica em JSON por enquanto;
// quando o módulo evoluir, viram tabelas próprias (Meal, FoodItem).
model MealPlan {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title     String
  content   String   @default("[]") // JSON: [{ meal: "Café da manhã", items: ["..."] }]
  createdAt DateTime @default(now())
}
