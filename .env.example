# Copie este arquivo para .env e preencha os valores.

# Local (SQLite): file:./dev.db
# Produção (Postgres/Neon): postgresql://usuario:senha@host/banco?sslmode=require
DATABASE_URL="file:./dev.db"

# Segredo que assina os cookies de sessão. Gere um novo com:
#   openssl rand -base64 32
AUTH_SECRET=""
